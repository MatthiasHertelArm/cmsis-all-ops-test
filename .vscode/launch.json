{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "FVP via fvp-gdb (attach)",
            "type": "gdbtarget",
            "request": "attach",
            "cwd": "${workspaceFolder}",
            "program": "${command:cmsis-csolution.getBinaryFile}",
            "gdb": "arm-none-eabi-gdb",
            "auxiliaryGdb": false,
            "//": "Run the 'FVP: Start' task once, then F5 / Shift+F5 cycle freely. 'load' pushes the current ELF into the running FVP each F5, so no restart needed after rebuilding. Use 'FVP: Stop' / 'FVP: Restart' only when the FVP itself misbehaves.",
            "initCommands": [
                "set arch arm",
                "set tdesc filename /dev/null",
                "monitor reset halt",
                "load",
                "monitor reset halt",
                "tbreak main"
            ],
            "target": {
                "port": "3333"
            }
        },
        {
            "name": "CMSIS_DAP@pyOCD (attach)",
            "type": "gdbtarget",
            "request": "attach",
            "cwd": "${workspaceFolder}",
            "program": "${command:cmsis-csolution.getBinaryFile}",
            "gdb": "arm-none-eabi-gdb",
            "auxiliaryGdb": false,
            "initCommands": [
                "set arch arm",
                "set tdesc filename /dev/null",
                "monitor reset halt",
                "load",
                "monitor reset halt",
                "tbreak main"
            ],
            "target": {
                "port": "3333"
            }
        }
    ]
}
